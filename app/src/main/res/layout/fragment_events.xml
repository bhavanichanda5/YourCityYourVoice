<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@color/white"
    tools:context=".Events">

    <!-- Grid Layout -->
    <GridLayout
        android:id="@+id/gridLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="center"
        android:columnCount="2"
        android:padding="8dp"
        android:background="@color/zxing_transparent"
        android:rowCount="3">

        <!-- Card 1: Yours -->
        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#6A8E38"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:id="@+id/yours"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView

                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/yours" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Yours"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card 2: Upcoming -->
        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#8A1E00"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:id="@+id/upcoming"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/event" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Upcoming"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card 3: Popular -->
        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#FF9800"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:id="@+id/popular"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/popular" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Popular"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card 4: Bookmarked -->
        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#6A1B9A"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:id="@+id/bookmarked"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/bookmark"
                    app:tint="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Bookmarked"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card 5: All -->
        <androidx.cardview.widget.CardView
            android:layout_width="130dp"
            android:layout_height="120dp"
            android:layout_margin="8dp"
            app:cardBackgroundColor="#0277BD"
            app:cardCornerRadius="10dp">

            <LinearLayout
                android:id="@+id/all"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/all" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="All"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/seegreen"
        app:cardCornerRadius="31dp">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:contentDescription="Add new item"
            android:src="@drawable/baseline_add_24"
            app:backgroundTint="@color/seegreen"
            app:fabSize="mini"
            app:tint="@color/white" />
    </androidx.cardview.widget.CardView>

</LinearLayout>
