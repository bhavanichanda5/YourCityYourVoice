<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Location">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/seegreen"
        android:titleTextColor="@android:color/white" />

    <!-- Map View -->
    <com.google.android.gms.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:contentDescription="Map displaying toilet locations"/>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <!-- Floating Action Button for current location -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCurrentLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="Find nearest toilet"
        android:src="@drawable/baseline_wc_24"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/white"
        app:cardCornerRadius="24dp"
        android:layout_below="@id/toolbar"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:background="@color/zxing_transparent"
                android:src="@drawable/baseline_search_24" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:hint="Search location"
                android:textColorHint="@color/grey"
                android:textSize="16sp"
                android:background="@null"
                android:paddingVertical="16dp"
                android:imeOptions="actionSearch"
                android:inputType="textCapWords|textAutoComplete"
                android:maxLines="1" />

            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@color/zxing_transparent"
                android:contentDescription="Search"
                android:scaleType="centerInside"
                android:src="@drawable/baseline_location_on_24" />

            <ImageButton
                android:id="@+id/btnClearSearch"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@color/zxing_transparent"
                android:src="@drawable/baseline_close_24"
                android:contentDescription="Search"
                android:padding="10dp"
                android:scaleType="centerInside" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>