<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="25dp"
    android:orientation="vertical"
    android:background="@drawable/background"
    tools:context=".otp">


    <ImageView
        android:id="@+id/imageView"
        android:layout_width="246dp"
        android:layout_height="105dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_gravity="center"
        android:padding="12dp"
        app:srcCompat="@drawable/chasma" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:elevation="500sp"
        app:cardBackgroundColor="@color/Green"
        app:cardCornerRadius="50sp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/welcome_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:padding="5dp"
            android:text="Forgot Password"
            android:textColor="#FFFEFE"
            android:textSize="20dp"
            android:textStyle="bold" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:elevation="500sp"
        app:cardCornerRadius="50sp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="9dp"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="Let Us Help You !"
                android:textColor="@color/darkorng"
                android:textSize="20dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/code"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:layout_marginLeft="9dp"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="VALIDATION CODE !"
                android:textColor="#040404"
                android:textSize="15dp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:gravity="center">

                    <EditText
                        android:id="@+id/otp_digit1"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@+id/otp_digit2"
                        android:background="@drawable/otp_input_background"  />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/otp_digit2"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@+id/otp_digit3"
                        android:nextFocusUp="@+id/otp_digit1"
                        android:background="@drawable/otp_input_background" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/otp_digit3"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@+id/otp_digit4"
                        android:nextFocusUp="@+id/otp_digit2"
                        android:background="@drawable/otp_input_background" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/otp_digit4"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@+id/otp_digit5"
                        android:nextFocusUp="@+id/otp_digit3"
                        android:background="@drawable/otp_input_background" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/otp_digit5"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionNext"
                        android:nextFocusDown="@+id/otp_digit6"
                        android:nextFocusUp="@+id/otp_digit4"
                        android:background="@drawable/otp_input_background" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/otp_digit6"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:inputType="number"
                        android:maxLength="1"
                        android:gravity="center"
                        android:imeOptions="actionDone"
                        android:nextFocusUp="@+id/otp_digit5"
                        android:background="@drawable/otp_input_background" />

                </LinearLayout>

                <Button
                    android:id="@+id/verify_otp_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="Verify OTP" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>
    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="118dp"
        android:layout_gravity="center"
        android:layout_marginTop="85dp"
        android:padding="12dp"
        app:srcCompat="@drawable/fourlion" />

</LinearLayout>
