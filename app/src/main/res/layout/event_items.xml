<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notification_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/search_bakground"
    android:backgroundTint="@color/seegreen"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="100sp">


        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="2">

            <ImageView
                android:id="@+id/event_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="@color/white"
                android:src="@drawable/img_6" />

            <TextView
                android:id="@+id/event_title"
                android:layout_width="154dp"
                android:layout_height="match_parent"
                android:text="Walls painting at City Surat"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/event_time"
                android:layout_width="204dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:layout_marginLeft="10dp"
                android:gravity="fill"
                android:text="10 min ago"
                android:textColor="#6A6F65"
                android:textSize="12sp"
                android:textStyle="bold" />
        </TableRow>

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

        <TextView
            android:id="@+id/organizer_name"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Surya K Patel"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textSize="20sp" />
    </TableRow>

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="50dp">

        <TextView
            android:id="@+id/event_location"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:drawableLeft="@drawable/baseline_location_on_24"
            android:drawableTint="@color/seegreen"
            android:fontFamily="sans-serif"
            android:gravity="fill"
            android:padding="5sp"
            android:text="location"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/eve_time"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:drawableLeft="@drawable/baseline_calendar_month_24"
            android:drawableTint="@color/seegreen"
            android:fontFamily="sans-serif"
            android:gravity="fill"
            android:padding="5sp"
            android:text="time"
            android:textSize="12sp" />

    </TableRow>
    <!--TableRow
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

        <TextView
            android:id="@+id/event_date"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fontFamily="sans-serif"
            android:text="dd-mm-yy and HH:MM"
            android:drawableLeft="@drawable/baseline_calendar_month_24"
            android:drawableTint="@color/seegreen"
            android:padding="5sp"
            android:textSize="16sp" />

    </TableRow>
    <TableRow
        android:layout_width="match_parent"
        android:layout_height="match_parent" >

        <TextView
            android:id="@+id/m"
            android:layout_width="167dp"
            android:layout_height="match_parent"
            android:drawableLeft="@drawable/baseline_front_hand_24"
            android:drawableTint="@color/seegreen"
            android:fontFamily="sans-serif"
            android:padding="5sp"
            android:text="Male Volunteers"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/f"
            android:layout_width="217dp"
            android:layout_height="match_parent"
            android:drawableLeft="@drawable/baseline_front_hand_24"
            android:drawableTint="@color/seegreen"
            android:fontFamily="sans-serif"
            android:padding="5sp"
            android:text="Female Volunteers"
            android:textSize="16sp"
            android:textStyle="bold" />
    </TableRow-->

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/event_img"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:backgroundTint="@color/white"
            android:src="@drawable/img_7" />


    </TableRow>

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/event_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="The wall paintings in Surat showcase vibrant art, reflecting the city's culture and promoting social awareness."
            android:textColor="#525C48"
            android:textSize="16sp" />
    </TableRow>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_share"
            app:tint="@color/Blue" />

        <ImageButton
            android:id="@+id/btn_bookmark"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/baseline_bookmark_border_24"
            app:tint="@color/seegreen" />
    </LinearLayout>



</LinearLayout>
