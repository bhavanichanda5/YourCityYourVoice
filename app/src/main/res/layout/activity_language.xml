<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".language"
    android:background="@android:color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/seegreen"
        android:titleTextColor="@android:color/white"/>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="246dp"
        android:layout_height="105dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        android:layout_gravity="center"
        android:padding="12dp"
        app:srcCompat="@drawable/chasma" />

    <LinearLayout
        android:layout_width="283dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="location Icon"
            android:src="@drawable/ic_kanguage"
            app:tint="@color/seegreen" />

        <Spinner
            android:id="@+id/spinnerLanguages"
            android:layout_width="249dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/edit_text_back"
            android:backgroundTint="@color/seegreen"
            android:entries="@array/language_array"
            android:padding="16dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnApplyLanguage"
        android:layout_width="183dp"
        android:layout_marginTop="20dp"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/Darkgreen"
        android:layout_gravity="center"
        android:text="Apply Language" />

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="wrap_content"
        android:layout_height="118dp"
        android:layout_gravity="center"
        android:layout_marginTop="180dp"
        android:padding="12dp"
        app:srcCompat="@drawable/fourlion" />
</LinearLayout>
